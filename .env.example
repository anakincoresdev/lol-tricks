# Riot Games API Key (Development key expires every 24h)
# Get yours at https://developer.riotgames.com/
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional — point the frontend at the external lol-tricks-api backend.
# When set, the champion search page calls this URL instead of the Nuxt
# server routes. Leave empty for local dev.
# NUXT_PUBLIC_API_BASE=https://lol-tricks-api.vercel.app
