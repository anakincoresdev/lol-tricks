# Origin of the lol-tricks-api backend. All Riot Games API calls go through it,
# so this app no longer needs RIOT_API_KEY. Do not include the `/api` path here:
# typed client methods already call `/api/riot/...`.
# Production default (used when env is not set): https://lol-tricks.com
# Local dev override: http://localhost:3001 (Nuxt dev uses 3000, backend on 3001)
NUXT_PUBLIC_API_BASE=http://localhost:3001
